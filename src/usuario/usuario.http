### =====================================================
### CREAR UN NUEVO USUARIO - Juan Perez
# @name crearJuanPerez
POST http://localhost:5500/api/Usuarios
Content-Type: application/json

{
  "nombre": "Juan",
  "apellido": "Perez",
  "tel": 41231234,
  "mail": "JuanPerez@gmail.com",
  "contrasena": "123456"
}

### =====================================================
### LOGIN DEL USUARIO CREADO PARA OBTENER TOKEN
POST http://localhost:5500/api/Usuarios/login
Content-Type: application/json

{
  "mail": "JuanPerez@gmail.com",
  "contrasena": "MiPass123"
}


### =====================================================
### OBTENER TODOS LOS USUARIOS
GET http://localhost:5500/api/Usuarios
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY4YjM4NTU2NTIyYzE5MWQ0YWY1MDhkYyIsIm1haWwiOiJKdWFuUGVyZXpAZ21haWwuY29tIiwiaWF0IjoxNzU2NjAwMzY3LCJleHAiOjE3NTY2MDM5Njd9.0nJlE3jwVLx4fhc1kA17f1MiW9GLOsev3JI1z-DRxKo

### =====================================================
### OBTENER UN USUARIO POR ID
@id = {{crearJuanPerez.response.body.data.id}}
GET http://localhost:5500/api/Usuarios/{{id}}
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6IjY4YjM4NTU2NTIyYzE5MWQ0YWY1MDhkYyIsIm1haWwiOiJKdWFuUGVyZXpAZ21haWwuY29tIiwiaWF0IjoxNzU2NjAwMzY3LCJleHAiOjE3NTY2MDM5Njd9.0nJlE3jwVLx4fhc1kA17f1MiW9GLOsev3JI1z-DRxKo


